OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini
AGENTGUARD_DEMO=email

# Persistence: memory (default) or sqlite (durable; required for compliance evidence)
AGENTGUARD_STORE=memory
AGENTGUARD_DB_PATH=agentguard.db

# Optional governance/security config files (JSON or YAML)
AGENTGUARD_POLICY_CONFIG=policy.example.json
AGENTGUARD_SECURITY_CONFIG=security.example.json

# Optional extra detection layers
AGENTGUARD_TRANSFORMERS=0
AGENTGUARD_LLM_JUDGE=0

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
